#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/docker-phase3 build
  bin/docker-phase3 check
  bin/docker-phase3 up
  bin/docker-phase3 setup
  bin/docker-phase3 test
  bin/docker-phase3 smoke
  bin/docker-phase3 all

Commands:
  build   Build the Ubuntu 20.04 / Ruby 2.7 / Rails 6 app image.
  check   Print Ruby version and verify Rails boots.
  up      Start the Rails app with docker compose.
  setup   Create databases, load schema, and seed development data.
  test    Run the test suite inside the container.
  smoke   Run the admin login smoke check against the running app.
  all     Run build, setup, check, test, then smoke.
USAGE
}

cmd="${1:-}"

case "$cmd" in
  build)
    docker compose build app-phase3
    ;;
  check)
    docker compose run --rm app-phase3 ruby -v
    docker compose run --rm app-phase3 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  up)
    docker compose up app-phase3
    ;;
  setup)
    docker compose run --rm app-phase3 bundle exec rake db:create db:schema:load db:seed
    docker compose run --rm -e RAILS_ENV=test app-phase3 bundle exec rake db:create db:schema:load
    ;;
  test)
    docker compose run --rm -e RAILS_ENV=test app-phase3 bundle exec rake test
    ;;
  smoke)
    echo "--- admin login smoke check ---"
    docker compose run --rm app-phase3 bundle exec rails runner '
session = ActionDispatch::Integration::Session.new(Rails.application)
session.get("/_admin/login")
raise "Login page failed (#{session.status})" unless session.status == 200
puts "GET /_admin/login: #{session.status} OK"

session.post("/_admin/login", params: {account: "admin", password: "admin"})
raise "Login POST failed (#{session.status})" unless [302, 301].include?(session.status)
puts "POST /_admin/login (admin/admin): #{session.status} REDIRECT OK"

puts "Smoke check passed."
'
    ;;
  all)
    "$0" build
    "$0" setup
    "$0" check
    "$0" test
    "$0" smoke
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
